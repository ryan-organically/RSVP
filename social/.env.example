# RSVP social poster config. Copy to social/.env.local (gitignored) and fill in.
# Never commit real values.

# --- Primary backend: self-hosted Postiz (one call, all platforms) ---
# Spin up: git clone https://github.com/gitroomhq/postiz-app && docker compose up -d
# Then connect each social account in the Postiz UI and create a public API key.
POSTIZ_API_URL=https://postiz.yourhost.com
POSTIZ_API_KEY=

# --- Direct per-platform CLIs (used with --direct, zero cost) ---
# Bluesky (install: cargo install skeet). Use an app password, not your main password.
BSKY_HANDLE=you.bsky.social
BSKY_APP_PASSWORD=
BSKY_HOST=https://bsky.social

# Mastodon (install: pipx install toot, then `toot login` once; it stores its own auth)
# no env needed beyond running `toot login`

# YouTube Shorts (install: youtubeuploader; needs a Google Cloud OAuth client.json)
# follow https://github.com/porjo/youtubeuploader for client_secrets/request token setup

# X/Twitter: no free CLI in 2026 (pay-per-use API). Post via Postiz or manually.
# TikTok / Instagram: need an audited app / business account; Postiz uploads as a draft you publish from the phone.
